{
  "functions": {
    "api/generate-image.js": {
      "maxDuration": 60
    },
"api/health.js": {
      "maxDuration": 10
    }
  },
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|node_modules/|src/|@vite/|@react-refresh|@fs/|public/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
